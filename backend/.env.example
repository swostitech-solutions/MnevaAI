# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
PUBLIC_URL=https://your-render-app.onrender.com

# ── Frontend (for CORS) ───────────────────────────────────────
FRONTEND_URL=https://your-frontend-url.com

# ── Database (Render PostgreSQL internal URL) ─────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# ── Redis (Render Redis internal URL) ────────────────────────
REDIS_URL=redis://red-xxxx:6379

# ── Qdrant (use Qdrant Cloud free tier) ──────────────────────
QDRANT_URL=https://xxxx.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_minimum
JWT_EXPIRES_IN=7d

# ── DeepSeek AI (Required) ────────────────────────────────────
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your_deepseek_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── OpenAI Whisper (Required for voice transcription) ─────────
# Get from: https://platform.openai.com
OPENAI_API_KEY=sk-your_openai_key

# ── Voyage AI (Embeddings) ────────────────────────────────────
# Free tier at: https://dash.voyageai.com
VOYAGE_API_KEY=your_voyage_key
EMBEDDING_DIMENSIONS=512
QDRANT_VECTOR_SIZE=512

# ── Google OAuth (Gmail, Calendar, Contacts, Fit) ─────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/api/gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://your-render-app.onrender.com/api/calendar/callback
GOOGLE_CONTACTS_REDIRECT_URI=https://your-render-app.onrender.com/api/contacts/callback
GOOGLE_FIT_REDIRECT_URI=https://your-render-app.onrender.com/api/googlefit/callback

# ── Mobile deep link scheme ───────────────────────────────────
MOBILE_APP_SCHEME=mneva

# ── Email (Resend) ────────────────────────────────────────────
# Free tier: https://resend.com (3000 emails/month)
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=Mneva AI <onboarding@resend.dev>

# ── File Storage (S3 — recommended for production) ──────────────
# Leave blank to use local disk (not persistent on Render free tier)
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
# AWS credentials — use IAM role on EC2/ECS, or set explicitly
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
