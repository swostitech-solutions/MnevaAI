# Mneva AI v2 - Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# During development: Use relative path (Vite proxy handles it)
# During production: Use absolute URL to backend
VITE_API_URL=/api

# Base URL for backend (used for absolute URLs)
# In development, Vite proxy will handle this
# In production, use your backend domain
VITE_API_BASE_URL=http://localhost:3001

# WebSocket URL for real-time communication
# In development, Vite proxy will handle this
# In production, use your backend domain with same protocol
VITE_SOCKET_URL=http://localhost:3001

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Development Server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Port for Vite dev server
VITE_DEV_SERVER_PORT=5174

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Build Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Environment (development, staging, production)
# This affects optimizations and debugging
VITE_ENV_MODE=development

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Feature Flags
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable debug mode (verbose console logs)
VITE_DEBUG=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Notes
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. In development:
#    - VITE_API_URL=/api (uses Vite proxy)
#    - VITE_SOCKET_URL=http://localhost:3001 or relative path
#    - VITE_DEV_SERVER_PORT=5174

# 2. In production (Docker):
#    - VITE_API_URL=/api (uses Nginx proxy)
#    - VITE_SOCKET_URL=https://yourdomain.com (use same domain)
#    - Build: npm run build

# 3. Socket.IO will automatically use correct protocol:
#    - Development: ws://localhost:3001
#    - Production (HTTPS): wss://yourdomain.com

# 4. For HTTPS in production:
#    - Update VITE_SOCKET_URL to use https://
#    - Socket.IO will automatically upgrade to wss://
